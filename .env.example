# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
SUPABASE_STORAGE_BUCKET=regulatory-docs

# API / frontend
APP_BASE_URL=https://regulatory-ai-web-5bbc.vercel.app
API_BASE_URL=https://regai-api-production.up.railway.app
NEXT_PUBLIC_API_BASE_URL=https://regai-api-production.up.railway.app
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=https://regai-api-production.up.railway.app
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://regulatory-ai-web-5bbc.vercel.app
CORS_ORIGIN_REGEX="^https://regulatory-ai-web-5bbc(?:-[a-z0-9-]+)?\\.vercel\\.app$"

# LLM
LLM_PROVIDER=parallel
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PARALLEL_API_KEY=
PARALLEL_BASE_URL=https://api.parallel.ai
LLM_MODEL_AGENT=base
LLM_MODEL_SUMMARY=base
LLM_MODEL_CHAT=speed

# Hybrid RAG
EMBEDDING_PROVIDER=offline
VECTOR_PROVIDER=supabase
RETRIEVAL_PROVIDER=supabase
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
OPENAI_COMPATIBLE_EMBEDDING_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_EMBEDDING_API_KEY=
RAG_CHUNK_MIN_TOKENS=600
RAG_CHUNK_MAX_TOKENS=800
RAG_CHUNK_OVERLAP_TOKENS=120
RAG_CONTEXT_TOKEN_LIMIT=6500
RAG_TOP_K=15

# Email
EMAIL_PROVIDER=offline
EMAIL_API_KEY=
EMAIL_FROM="Regulatory AI <updates@example.com>"

# Ops
SENTRY_DSN=
CRAWL_USER_AGENT="RegulatoryAI-bot/0.1 (+https://example.com/bot)"
